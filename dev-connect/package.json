{
  "name": "dev-connect-monorepo",
  "private": true,
  "workspaces": [
    "candidate-dashboard",
    "company-dashboard",
    "signup-signin",
    "skills-page",
    "skill-extractor",
    "resume-maker",
    "ATS-analyzer",
    "streak-extractor"
  ],
  "scripts": {
    "install": "npm install",
    "dev:candidate": "npm --workspace candidate-dashboard run dev",
    "dev:company": "npm --workspace company-dashboard run dev",
    "dev:auth": "npm --workspace signup-signin run dev",
    "dev:skills": "npm --workspace skills-page run dev",
    "dev:resume": "npm --workspace resume-maker run dev",
    "dev:extractor": "npm --workspace skill-extractor run dev",
    "dev:streak": "npm --workspace streak-extractor run dev",
    "build:candidate": "npm --workspace candidate-dashboard run build",
    "build:company": "npm --workspace company-dashboard run build",
    "build:auth": "npm --workspace signup-signin run build",
    "build:skills": "npm --workspace skills-page run build",
    "build:resume": "npm --workspace resume-maker run build",
    "build:extractor": "npm --workspace skill-extractor run build",
    "build:streak": "npm --workspace streak-extractor run build",
    "build:all": "npm run build:candidate && npm run build:company && npm run build:auth && npm run build:skills && npm run build:resume && npm run build:extractor && npm run build:streak",
    "lint:candidate": "npm --workspace candidate-dashboard run lint",
    "lint:company": "npm --workspace company-dashboard run lint",
    "lint:auth": "npm --workspace signup-signin run lint",
    "lint:skills": "npm --workspace skills-page run lint",
    "lint:resume": "npm --workspace resume-maker run lint",
    "lint:extractor": "npm --workspace skill-extractor run lint",
    "test:candidate": "npm --workspace candidate-dashboard run test",
    "test:company": "npm --workspace company-dashboard run test",
    "test:auth": "npm --workspace signup-signin run test",
    "test:skills": "npm --workspace skills-page run test",
    "test:resume": "npm --workspace resume-maker run test",
    "test:extractor": "npm --workspace skill-extractor run test"
  }
}
